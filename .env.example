# ── Base ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/insightforge

# ── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Environnement ─────────────────────────────────────────────────────────────
# Valeurs possibles : development | staging | production
ENVIRONMENT=development

# ── Étape 6 — Alertes ─────────────────────────────────────────────────────────
# Slack : créer un Incoming Webhook sur https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Resend : récupérer la clé sur https://resend.com/api-keys
RESEND_API_KEY=re_...

# Email expéditeur et destinataire des alertes
ALERT_EMAIL_FROM=alerts@insightforge.ai
ALERT_EMAIL_TO=admin@insightforge.ai

# Seuil churn pour déclencher une alerte (0.0 – 1.0)
CHURN_ALERT_THRESHOLD=0.7
